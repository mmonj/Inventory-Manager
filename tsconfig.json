{
    "compilerOptions": {
        "strict": true,
        "sourceMap": true,
        "noEmit": true,
        "module": "commonjs",
        "target": "es2017",
        "esModuleInterop": true,
        "allowJs": true,
        "jsx": "react",
        "skipLibCheck": true,
        "paths": {
            "@client/*": [
                "./client/*"
            ],
            "@reactivated": [
                "./node_modules/_reactivated"
            ],
            "@static/*": [
                "./static/*"
            ]
        }
    },
    "include": [
        "./client/**/*"
    ]
}
